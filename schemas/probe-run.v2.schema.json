{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jieyanggucheng.local/schemas/probe-run.v2.schema.json",
  "type": "object",
  "required": ["schema", "probe_id", "route_revision_id", "question", "method", "expected_evidence", "budget", "producer_actor_id", "execution_status", "non_publishable"],
  "properties": {
    "schema": {"const": "blender-harness.probe-run.v2"},
    "probe_id": {"type": "string", "minLength": 1},
    "route_revision_id": {"type": "string", "minLength": 1},
    "question": {"type": "string", "minLength": 1},
    "method": {"type": "string", "minLength": 1},
    "expected_evidence": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "missing_expected_evidence": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "budget": {"type": "object"},
    "producer_actor_id": {"type": "string", "minLength": 1},
    "execution_status": {"enum": ["planned", "running", "succeeded", "failed", "canceled"]},
    "finding": {"type": ["string", "null"], "enum": ["supports", "refutes", "inconclusive", null]},
    "confidence": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
    "evidence_bundle_id": {"type": ["string", "null"]},
    "result_summary": {"type": ["string", "null"]},
    "non_publishable": {"const": true},
    "created_at": {"type": "string"},
    "updated_at": {"type": "string"}
  },
  "additionalProperties": false
}
