{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "blender-harness.experience-record.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["experience_id", "context_id", "recipe_ref", "route_workspace", "route_revision_id", "probe_id", "evidence_bundle_id", "evidence_bundle_sha256", "review_refs", "decision_ref", "execution_mode", "publication_status", "input_artifacts", "step_execution_refs", "execution_status", "finding", "provider_statuses", "artifact_statuses", "outcome_id", "producer_actor_id", "reviewer_actor_ids", "ingested_by", "created_at", "schema"],
  "properties": {
    "experience_id": {"type": "string", "minLength": 1},
    "context_id": {"type": "string", "minLength": 1},
    "recipe_ref": {"type": "string", "minLength": 3},
    "route_workspace": {"type": "string", "minLength": 1},
    "route_revision_id": {"type": "string", "minLength": 1},
    "probe_id": {"type": "string", "minLength": 1},
    "evidence_bundle_id": {"type": "string", "minLength": 1},
    "evidence_bundle_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "review_refs": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["review_id", "sha256"]}},
    "decision_ref": {"type": "object", "required": ["decision_id", "sha256"]},
    "execution_mode": {"enum": ["explore", "shadow", "production"]},
    "publication_status": {"enum": ["non_publishable", "external_authority_required"]},
    "input_artifacts": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["role", "sha256", "provenance_ref", "hash_provenance"]}},
    "step_execution_refs": {"type": "array", "items": {"type": "object"}},
    "execution_status": {"enum": ["succeeded", "failed", "canceled"]},
    "finding": {"enum": ["supports", "refutes", "inconclusive"]},
    "provider_statuses": {"type": "object", "additionalProperties": {"type": "string"}},
    "artifact_statuses": {"type": "object", "additionalProperties": {"type": "string"}},
    "outcome_id": {"type": "string", "minLength": 1},
    "producer_actor_id": {"type": "string", "minLength": 1},
    "reviewer_actor_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "ingested_by": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "schema": {"const": "blender-harness.experience-record.v1"}
  }
}
