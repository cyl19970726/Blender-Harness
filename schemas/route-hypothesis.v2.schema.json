{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jieyanggucheng.local/schemas/route-hypothesis.v2.schema.json",
  "type": "object",
  "required": ["schema", "route_id", "revision_id", "goal", "assumptions", "unknowns", "cheapest_falsification", "stop_conditions", "budget", "alternatives", "scope", "parent_revision_ids", "created_by"],
  "properties": {
    "schema": {"const": "blender-harness.route-hypothesis.v2"},
    "route_id": {"type": "string", "minLength": 1},
    "revision_id": {"type": "string", "minLength": 1},
    "parent_revision_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "goal": {"type": "string", "minLength": 1},
    "assumptions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "unknowns": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "cheapest_falsification": {"type": "object", "minProperties": 1},
    "stop_conditions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "budget": {"type": "object"},
    "alternatives": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "scope": {"type": "object"},
    "created_by": {"type": "string", "minLength": 1},
    "created_at": {"type": "string"}
  },
  "additionalProperties": false
}
