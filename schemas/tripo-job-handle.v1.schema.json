{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jieyanggucheng.local/schemas/tripo-job-handle.v1.schema.json",
  "title": "Blender Harness Tripo JobHandle v1",
  "type": "object",
  "required": ["schema", "handle_id", "provider", "operation", "submit_endpoint", "request_hash", "idempotency_key", "credential_fingerprint", "provider_status", "artifact_status", "submission_status", "submitted_at", "updated_at", "artifact_deadline"],
  "properties": {
    "schema": {"const": "blender-harness.tripo-job-handle.v1"},
    "handle_id": {"type": "string", "pattern": "^[a-f0-9]{24}$"},
    "provider": {"const": "tripo"},
    "operation": {"type": "string", "minLength": 1},
    "submit_endpoint": {"type": "string", "pattern": "^/"},
    "task_id": {"type": ["string", "null"]},
    "request_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "idempotency_key": {"type": "string", "minLength": 1},
    "credential_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{16}$"},
    "trace_id": {"type": ["string", "null"]},
    "status": {"enum": ["WAIT", "RUN", "DONE", "FAIL", "UNKNOWN"]},
    "provider_status": {"enum": ["WAIT", "RUN", "DONE", "FAIL", "UNKNOWN"]},
    "artifact_status": {"enum": ["NOT_READY", "PENDING", "FETCHING", "FETCH_FAILED", "VERIFIED"]},
    "submission_status": {"enum": ["RESERVED", "SUBMITTING", "SUBMIT_UNKNOWN", "SUBMIT_FAILED", "SUBMITTED"]},
    "artifact_error": {"type": ["string", "null"]},
    "submission_error": {"type": ["string", "null"]},
    "submitted_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "artifact_deadline": {"type": ["string", "null"], "format": "date-time"},
    "result_url_observed_at": {"type": ["string", "null"], "format": "date-time"},
    "result_url_expires_at": {"type": ["string", "null"], "format": "date-time"},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "last_response": {"type": "object"}
  },
  "additionalProperties": true
}
