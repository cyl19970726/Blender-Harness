{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jieyanggucheng.local/schemas/review-record.v1.schema.json",
  "type": "object",
  "required": ["schema", "review_id", "route_revision_id", "probe_id", "evidence_bundle_id", "reviewer_actor_id", "reviewer_role", "recommendation", "reason"],
  "properties": {
    "schema": {"const": "blender-harness.review-record.v1"},
    "review_id": {"type": "string", "minLength": 1},
    "route_revision_id": {"type": "string", "minLength": 1},
    "probe_id": {"type": "string", "minLength": 1},
    "evidence_bundle_id": {"type": "string", "minLength": 1},
    "reviewer_actor_id": {"type": "string", "minLength": 1},
    "reviewer_role": {"type": "string", "minLength": 1},
    "recommendation": {"enum": ["continue", "revise", "abandon", "ask_owner"]},
    "reason": {"type": "string", "minLength": 1},
    "knowledge_refs": {"type": "array", "items": {"type": "string"}},
    "created_at": {"type": "string"}
  },
  "additionalProperties": false
}
