{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jieyanggucheng.local/schemas/evidence-bundle.v1.schema.json",
  "type": "object",
  "required": ["schema", "evidence_id", "probe_id", "route_revision_id", "producer_actor_id", "items", "created_at"],
  "properties": {
    "schema": {"const": "blender-harness.evidence-bundle.v1"},
    "evidence_id": {"type": "string", "minLength": 1},
    "probe_id": {"type": "string", "minLength": 1},
    "route_revision_id": {"type": "string", "minLength": 1},
    "producer_actor_id": {"type": "string", "minLength": 1},
    "items": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["role", "path", "media_type", "sha256", "size_bytes"]}},
    "created_at": {"type": "string"}
  },
  "additionalProperties": false
}
