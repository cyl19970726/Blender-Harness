{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "blender-harness.comparison-set.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["comparison_id", "context_id", "comparison_design", "candidate_experience_ids", "controlled_factors", "declared_confounders", "metric_ids", "status", "blockers", "uncertainties", "pareto_recipe_refs", "dominated_by", "spec_hash", "created_by", "created_at", "schema"],
  "properties": {
    "comparison_id": {"type": "string", "minLength": 1},
    "context_id": {"type": "string", "minLength": 1},
    "comparison_design": {"enum": ["single_step_same_input", "end_to_end_same_target"]},
    "candidate_experience_ids": {"type": "array", "minItems": 2, "items": {"type": "string", "minLength": 1}},
    "controlled_factors": {"type": "object"},
    "declared_confounders": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "metric_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "status": {"enum": ["comparable", "incomparable"]},
    "blockers": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "uncertainties": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "pareto_recipe_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "dominated_by": {"type": "object", "additionalProperties": {"type": "array", "items": {"type": "string"}}},
    "spec_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "created_by": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "schema": {"const": "blender-harness.comparison-set.v1"}
  }
}
