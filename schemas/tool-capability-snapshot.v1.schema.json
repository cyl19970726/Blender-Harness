{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "blender-harness.tool-capability-snapshot.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["snapshot_id", "capability_key", "tool_id", "executor_kind", "provider", "transport", "operation", "model_name", "model_version", "api_version", "adapter_commit", "captured_at", "source_documents", "parameter_contracts", "input_roles", "output_roles", "documented_pricing", "verification_level", "evidence_refs", "conflicts", "revalidate_when", "created_by", "schema"],
  "properties": {
    "snapshot_id": {"type": "string", "minLength": 1},
    "capability_key": {"type": "string", "minLength": 1},
    "tool_id": {"type": "string", "minLength": 1},
    "executor_kind": {"type": "string", "minLength": 1},
    "provider": {"type": "string", "minLength": 1},
    "transport": {"type": "string", "minLength": 1},
    "operation": {"type": "string", "minLength": 1},
    "model_name": {"type": "string", "minLength": 1},
    "model_version": {"type": "string", "minLength": 1},
    "api_version": {"type": "string", "minLength": 1},
    "adapter_commit": {"type": "string", "minLength": 1},
    "captured_at": {"type": "string", "minLength": 1},
    "source_documents": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["url", "observed_at"]}},
    "parameter_contracts": {"type": "object", "additionalProperties": {"type": "object", "required": ["requires_resolution"]}},
    "input_roles": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "output_roles": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "documented_pricing": {"type": "object"},
    "verification_level": {"enum": ["official_only", "recorded", "live_verified", "blender_verified"]},
    "evidence_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "conflicts": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "revalidate_when": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "created_by": {"type": "string", "minLength": 1},
    "schema": {"const": "blender-harness.tool-capability-snapshot.v1"}
  }
}
