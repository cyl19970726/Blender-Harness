{
  "version": "asset-profiles-v01",
  "description": "Reusable Blender harness profile contract for Jieyang Gucheng 3D assets. Profiles define required evidence; visual acceptance remains in reviews.",
  "common_gates": {
    "asset_art": {
      "intent": "Prove the asset is visually credible before retopo, rig, motion, pass, or runtime work.",
      "required_artifacts": [
        "material_preview_board",
        "clay_board",
        "wireframe_board",
        "silhouette_board",
        "no_helper_viewport_board",
        "primary_closeup_board",
        "asset_art_audit"
      ],
      "no_helper_artifacts": [
        "material_preview_board",
        "no_helper_viewport_board",
        "primary_closeup_board"
      ],
      "required_review_roles": [
        "asset_art_reviewer",
        "fresh_visual_reviewer"
      ],
      "required_prompt_ids": [
        "asset-art-review-v01",
        "reference-compare-review-v01",
        "failure-case-checklist-v01"
      ]
    },
    "topology_uv": {
      "intent": "Prove the accepted art source has deformation-ready topology and usable UV/material continuity.",
      "required_artifacts": [
        "topology_wireframe_board",
        "edge_loop_closeup_board",
        "uv_layout_board",
        "texel_density_board",
        "bake_check_board",
        "topology_uv_audit"
      ],
      "no_helper_artifacts": [
        "edge_loop_closeup_board",
        "uv_layout_board"
      ],
      "required_review_roles": [
        "topology_reviewer",
        "uv_material_reviewer"
      ],
      "required_prompt_ids": [
        "topology-uv-review-v01",
        "reference-compare-review-v01",
        "failure-case-checklist-v01"
      ]
    },
    "rig_deformation": {
      "intent": "Prove the rig deforms the asset under the poses that the final animation will require.",
      "required_artifacts": [
        "neutral_pose_board",
        "extreme_pose_board",
        "closeup_deformation_board",
        "rig_hierarchy_audit",
        "skin_weight_audit"
      ],
      "no_helper_artifacts": [
        "closeup_deformation_board"
      ],
      "required_review_roles": [
        "rig_reviewer",
        "deformation_reviewer",
        "fresh_visual_reviewer"
      ],
      "required_prompt_ids": [
        "rig-deformation-review-v01",
        "reference-compare-review-v01",
        "failure-case-checklist-v01"
      ]
    },
    "animation": {
      "intent": "Prove motion and camera blocking/polish from multiple views before source-pass work.",
      "required_artifacts": [
        "camera_playblast",
        "camera_timeline_board",
        "top_timeline_board",
        "side_timeline_board",
        "asset_only_timeline_board",
        "high_coverage_contact_sheet",
        "animation_audit"
      ],
      "no_helper_artifacts": [
        "camera_timeline_board",
        "high_coverage_contact_sheet"
      ],
      "required_review_roles": [
        "animation_reviewer",
        "fresh_visual_reviewer"
      ],
      "required_prompt_ids": [
        "animation-review-v01",
        "reference-compare-review-v01",
        "failure-case-checklist-v01"
      ]
    },
    "source_pass": {
      "intent": "Prove beauty/pass/matte ownership is same-source and named before any runtime packaging.",
      "required_artifacts": [
        "beauty_contact_sheet",
        "pass_breakdown_board",
        "owner_collection_manifest",
        "matte_contact_sheet",
        "source_pass_audit",
        "runtime_boundary_audit"
      ],
      "no_helper_artifacts": [
        "beauty_contact_sheet",
        "matte_contact_sheet"
      ],
      "required_review_roles": [
        "source_pass_reviewer",
        "runtime_boundary_reviewer",
        "fresh_visual_reviewer"
      ],
      "required_prompt_ids": [
        "source-pass-review-v01",
        "reference-compare-review-v01",
        "failure-case-checklist-v01"
      ]
    }
  },
  "profiles": {
    "long_creature": {
      "description": "Long-bodied creature such as Loong/Chinese dragon. Protects head-neck-body continuity and coil/lunge deformation.",
      "examples": ["Jinxianmen long dragon"],
      "hard_rejects": [
        "head_neck_body_seam_visible",
        "decorated_tube_or_slab_body",
        "helper_collar_or_socket_masks_art_failure",
        "scale_or_belly_flow_breaks_at_neck_or_tail",
        "coil_or_lunge_closeup_collapses"
      ],
      "gates": {
        "asset_art": {
          "required_artifacts": [
            "head_neck_closeup_board",
            "belly_dorsal_closeup_board",
            "tail_root_closeup_board",
            "scale_flow_callout_board"
          ],
          "no_helper_artifacts": [
            "head_neck_closeup_board",
            "tail_root_closeup_board"
          ]
        },
        "topology_uv": {
          "required_artifacts": [
            "head_neck_loop_board",
            "body_ring_loop_board",
            "belly_uv_continuity_board"
          ]
        },
        "rig_deformation": {
          "required_artifacts": [
            "s_curve_pose_board",
            "tight_coil_pose_board",
            "around_column_pose_board",
            "near_lens_lunge_pose_board",
            "head_turn_jaw_board",
            "tail_whip_board",
            "claw_spread_board"
          ]
        },
        "animation": {
          "required_artifacts": [
            "orbit_path_board",
            "near_lens_lunge_contact_sheet",
            "head_neck_motion_closeup_board"
          ]
        }
      }
    },
    "humanoid_character": {
      "description": "Stylized or mascot humanoid character, such as Jie Xiaoxian.",
      "examples": ["Jie Xiaoxian"],
      "hard_rejects": [
        "face_or_silhouette_off_character",
        "generic_game_npc_read",
        "hands_or_face_collapse_in_closeup",
        "accessory_or_clothing_not_bound",
        "retarget_motion_breaks_character_personality"
      ],
      "gates": {
        "asset_art": {
          "required_artifacts": [
            "face_closeup_board",
            "body_proportion_board",
            "outfit_material_board",
            "accessory_closeup_board"
          ],
          "no_helper_artifacts": [
            "face_closeup_board",
            "outfit_material_board"
          ]
        },
        "topology_uv": {
          "required_artifacts": [
            "face_loop_board",
            "shoulder_elbow_hand_loop_board",
            "outfit_uv_board"
          ]
        },
        "rig_deformation": {
          "required_artifacts": [
            "face_expression_board",
            "hand_pose_board",
            "sleeve_accessory_deformation_board",
            "retarget_neutral_pose_board"
          ]
        },
        "animation": {
          "required_artifacts": [
            "gesture_timing_board",
            "facial_expression_timeline_board",
            "character_personality_review_board"
          ]
        }
      }
    },
    "historical_figure": {
      "description": "Historical human figure, such as Guo Zhiqi, where costume accuracy and dignity matter.",
      "examples": ["Guo Zhiqi"],
      "hard_rejects": [
        "historical_costume_inaccurate",
        "generic_game_npc_or_actor_read",
        "robe_or_sleeve_deformation_collapses",
        "gesture_tone_inappropriate",
        "face_age_or_dignity_mismatch"
      ],
      "gates": {
        "asset_art": {
          "required_artifacts": [
            "face_age_dignity_closeup_board",
            "historical_costume_board",
            "robe_sleeve_material_board",
            "cultural_tone_board"
          ],
          "no_helper_artifacts": [
            "face_age_dignity_closeup_board",
            "historical_costume_board"
          ]
        },
        "topology_uv": {
          "required_artifacts": [
            "face_loop_board",
            "robe_sleeve_loop_board",
            "costume_uv_continuity_board"
          ]
        },
        "rig_deformation": {
          "required_artifacts": [
            "gesture_pose_board",
            "robe_sleeve_deformation_board",
            "head_neck_hand_closeup_board"
          ]
        },
        "animation": {
          "required_artifacts": [
            "gesture_timing_board",
            "cultural_tone_motion_board",
            "robe_motion_closeup_board"
          ]
        }
      }
    },
    "building_prop": {
      "description": "Architectural or scenic prop used in AR scenes.",
      "examples": ["Jinxianmen tower", "plinth", "railing"],
      "hard_rejects": [
        "structure_not_integrated",
        "floating_or_unjoined_building_parts",
        "near_lens_detail_reads_procedural_or_low_quality",
        "wrong_anchor_or_scale",
        "pass_owner_not_separable"
      ],
      "gates": {
        "asset_art": {
          "required_artifacts": [
            "structure_join_closeup_board",
            "material_detail_closeup_board",
            "scale_anchor_board"
          ]
        },
        "topology_uv": {
          "required_artifacts": [
            "hard_edge_normal_board",
            "modular_piece_pivot_board",
            "material_uv_board"
          ]
        },
        "rig_deformation": {
          "required_artifacts": [
            "transform_pivot_board",
            "destruction_or_motion_if_applicable_board"
          ]
        },
        "animation": {
          "required_artifacts": [
            "camera_parallax_board",
            "occlusion_edge_contact_sheet"
          ]
        }
      }
    },
    "product_prop": {
      "description": "Small product or cultural object prop, including magnets, tea ware, food props, and handheld assets.",
      "examples": ["fridge magnet", "teapot", "oyster omelette", "tofu prop"],
      "hard_rejects": [
        "product_shape_not_readable",
        "material_not_product_grade",
        "edge_owner_unclear",
        "closeup_texture_muddy",
        "scale_not_consistent_with_card_or_marker"
      ],
      "gates": {
        "asset_art": {
          "required_artifacts": [
            "product_edge_closeup_board",
            "material_finish_board",
            "scale_with_marker_board"
          ]
        },
        "topology_uv": {
          "required_artifacts": [
            "edge_loop_or_hard_edge_board",
            "product_uv_layout_board",
            "material_bake_board"
          ]
        },
        "rig_deformation": {
          "required_artifacts": [
            "transform_control_board",
            "hinge_or_secondary_motion_board"
          ]
        },
        "animation": {
          "required_artifacts": [
            "product_reveal_timeline_board",
            "edge_owner_motion_board"
          ]
        }
      }
    }
  }
}
