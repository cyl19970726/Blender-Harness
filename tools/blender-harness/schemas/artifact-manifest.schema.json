{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jygc.blender-harness.artifact-manifest.v1",
  "title": "Blender Harness Artifact Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": ["candidate_id", "artifacts"],
  "properties": {
    "candidate_id": { "type": "string", "minLength": 1 },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "type", "path"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": {
            "enum": ["board", "video", "audit", "manifest", "model", "texture", "source", "review"]
          },
          "path": { "type": "string", "minLength": 1 },
          "gate": { "type": "string" },
          "helper_overlay": { "type": "boolean" },
          "usable": { "type": "boolean" },
          "sha256": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
